{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    ":dependencyDashboard"
  ],
  "pinDigests": true,
  "pinTags": false,
  "labels": [
    "dependencies"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "github-actions",
        "dockerfile"
      ],
      "matchUpdateTypes": [
        "digest",
        "minor",
        "patch"
      ],
      "groupName": "non-major infrastructure updates",
      "labels": [
        "dependencies",
        "github-actions",
        "docker"
      ]
    }
  ]
}
